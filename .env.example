# Supabase (frontend-safe values only — never put the service role key here)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

OPENROUTER_API_KEY=
# Default model. gemini-2.5-flash-lite is multimodal (reads report photos and
# scanned PDFs) and very low cost — every call is logged with tokens + cost by
# the dev API server. Only allowlisted models are accepted (see
# server/openrouterClient.mjs).
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_RETRY_ON_PARSE_ERROR=false
