{
  "name": "@verae/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "auth:generate": "auth generate --config src/auth/auth.ts --output migrations/0001_better_auth.sql --yes",
    "bootstrap:admin": "tsx src/scripts/bootstrap-admin.ts",
    "db:provision-logins": "tsx src/scripts/provision-logins.ts",
    "partner:credential": "tsx src/scripts/create-partner-credential.ts",
    "openapi:generate": "tsx src/scripts/generate-openapi.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.911.0",
    "@aws-sdk/s3-request-presigner": "^3.911.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.6.1",
    "@scalar/fastify-api-reference": "^1.36.1",
    "@verae/contracts": "workspace:*",
    "better-auth": "^1.6.23",
    "dotenv": "^17.2.3",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "file-type": "^21.1.0",
    "kysely": "^0.29.3",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "pg-boss": "^12.26.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "auth": "^1.6.23",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
