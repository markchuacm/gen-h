NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://verae:verae@localhost:5432/verae
WORKER_DATABASE_URL=
PROCESS_ROLE=api
# Production migrations/bootstrap use the owner credential only for that command.
DATABASE_ADMIN_URL=
# Production uses separate least-privilege authentication and queue logins.
AUTH_DATABASE_URL=
JOBS_DATABASE_URL=
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:4000
APP_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_URL=
EMAIL_FROM=Verae Health <noreply@veraehealth.com>
TURNSTILE_SECRET_KEY=
REQUIRE_TURNSTILE=false
S3_ENDPOINT=http://localhost:9000
S3_REGION=my-1
S3_ACCESS_KEY_ID=verae-local
S3_SECRET_ACCESS_KEY=verae-local-secret
S3_DOCUMENTS_BUCKET=verae-documents
S3_BACKUPS_BUCKET=verae-backups
S3_FORCE_PATH_STYLE=true
CLAMAV_HOST=
CLAMAV_PORT=3310
# Generate with: openssl rand -base64 32
PARTNER_CREDENTIAL_ENCRYPTION_KEY=
REQUIRE_STAFF_MFA=false
LAB_TIMESTAMP_TOLERANCE_SECONDS=300
LAB_MAX_BODY_BYTES=5242880
BOOTSTRAP_ADMIN_TOKEN=
# Generate interactively with: pnpm --filter @verae/api developer:password
DEVELOPER_MODE_PASSWORD_HASH=
LOG_LEVEL=info
