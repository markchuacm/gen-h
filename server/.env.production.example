NODE_ENV=production
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://verae_api_login:REPLACE@postgres:5432/verae
WORKER_DATABASE_URL=postgres://verae_worker_login:REPLACE@postgres:5432/verae
PROCESS_ROLE=api
# Set only on one-off migration/bootstrap containers; never on the long-running API or worker.
DATABASE_ADMIN_URL=
AUTH_DATABASE_URL=postgres://verae_auth_login:REPLACE@postgres:5432/verae?options=-c%20search_path%3Didentity
JOBS_DATABASE_URL=postgres://verae_jobs_login:REPLACE@postgres:5432/verae
BETTER_AUTH_SECRET=REPLACE_WITH_64_RANDOM_CHARACTERS
BETTER_AUTH_URL=https://api.veraehealth.com
APP_ORIGIN=https://app.veraehealth.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_URL=smtps://REPLACE
EMAIL_FROM=Verae Health <noreply@veraehealth.com>
TURNSTILE_SECRET_KEY=
S3_ENDPOINT=https://REPLACE.my
S3_REGION=my-1
S3_ACCESS_KEY_ID=REPLACE
S3_SECRET_ACCESS_KEY=REPLACE
S3_DOCUMENTS_BUCKET=verae-documents
S3_BACKUPS_BUCKET=verae-backups
S3_FORCE_PATH_STYLE=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
PARTNER_CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_32
REQUIRE_STAFF_MFA=false
LAB_TIMESTAMP_TOLERANCE_SECONDS=300
LAB_MAX_BODY_BYTES=5242880
BOOTSTRAP_ADMIN_TOKEN=REPLACE_WITH_ONE_TIME_RANDOM_TOKEN
LOG_LEVEL=info
