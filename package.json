{
  "name": "verae-health",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "pnpm --filter @verae/api dev",
    "dev:all": "pnpm --parallel --filter verae-health --filter @verae/api dev",
    "build": "tsc -b && vite build",
    "build:all": "pnpm --filter @verae/contracts build && pnpm --filter @verae/api build && pnpm build",
    "test": "pnpm --filter @verae/api test && node scripts/assert-production-boundaries.mjs",
    "db:migrate": "pnpm --filter @verae/api db:migrate",
    "db:seed": "pnpm --filter @verae/api db:seed",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@gutenye/ocr-browser": "^1.4.8",
    "@vitejs/plugin-react": "^5.0.4",
    "better-auth": "^1.6.23",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "pdfjs-dist": "^5.4.296",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
