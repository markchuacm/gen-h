{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; connect-src 'self' https://api.veraehealth.com https://api-uat.veraehealth.com https://challenges.cloudflare.com https://s3.ap-southeast-5.amazonaws.com https://*.s3.ap-southeast-5.amazonaws.com; img-src 'self' data: blob: https://s3.ap-southeast-5.amazonaws.com https://*.s3.ap-southeast-5.amazonaws.com; media-src 'self'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; upgrade-insecure-requests" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/member",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/member/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "redirects": [
    {
      "source": "/member.html",
      "destination": "/member",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.veraehealth.com" }],
      "destination": "/member",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app-uat.veraehealth.com" }],
      "destination": "/member",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/terms-of-service", "destination": "/index.html" },
    { "source": "/privacy-policy", "destination": "/index.html" },
    { "source": "/informed-consent-policy", "destination": "/index.html" },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.veraehealth.com" }],
      "destination": "/member.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app-uat.veraehealth.com" }],
      "destination": "/member.html"
    },
    { "source": "/member", "destination": "/member.html" },
    { "source": "/member/(.*)", "destination": "/member.html" }
  ]
}
