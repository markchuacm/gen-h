# Application environment for AWS Lightsail staging (api-uat).
# Copy to server/.env.staging on the staging instance (chmod 600).
# Staging holds invented data only — never real member data.
NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Local postgres container (see infra/aws/compose.staging.yml).
DATABASE_URL=postgres://verae_api_login:CHANGE_ME@postgres:5432/verae
AUTH_DATABASE_URL=postgres://verae_auth_login:CHANGE_ME@postgres:5432/verae
WORKER_DATABASE_URL=postgres://verae_worker_login:CHANGE_ME@postgres:5432/verae
JOBS_DATABASE_URL=postgres://verae_jobs_login:CHANGE_ME@postgres:5432/verae

BETTER_AUTH_SECRET=CHANGE_ME_32_CHARS_MIN
BETTER_AUTH_URL=https://api-uat.veraehealth.com
APP_ORIGIN=https://app-uat.veraehealth.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_URL=
EMAIL_FROM=Verae Health <noreply@veraehealth.com>
TURNSTILE_SECRET_KEY=

# Staging Lightsail bucket — separate bucket and access key from production.
S3_ENDPOINT=https://s3.ap-southeast-5.amazonaws.com
S3_REGION=ap-southeast-5
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_DOCUMENTS_BUCKET=CHANGE_ME
S3_BACKUPS_BUCKET=CHANGE_ME
S3_FORCE_PATH_STYLE=false

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
PARTNER_CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME
REQUIRE_STAFF_MFA=false
# Staging publishes the API reference at /docs for partner integration work.
# Production leaves this unset so the route map stays private.
EXPOSE_API_DOCS=true
LOG_LEVEL=info
