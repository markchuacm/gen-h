# Compose-level environment for infra/aws/compose.staging.yml.
# Copy to infra/aws/.env.staging on the staging instance (chmod 600).
ACME_EMAIL=ops@veraehealth.com
API_DOMAIN=api-uat.veraehealth.com
POSTGRES_DB=verae
POSTGRES_USER=verae_owner
POSTGRES_PASSWORD=CHANGE_ME
# Staging admin URL points at the local postgres container's superuser.
DATABASE_ADMIN_URL=postgres://verae_owner:CHANGE_ME@postgres:5432/verae
