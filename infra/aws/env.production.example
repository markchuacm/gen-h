# Compose-level environment for infra/aws/compose.production.yml.
# Copy to infra/aws/.env.production on the production instance (chmod 600).
ACME_EMAIL=ops@veraehealth.com
API_DOMAIN=api.veraehealth.com
# Lightsail managed-database master credential. Only the profile-gated tools
# service (migrations / provision-logins) receives this URL.
# URL-encode the password if it contains special characters.
DATABASE_ADMIN_URL=postgres://dbmasteruser:CHANGE_ME@PRIVATE_DB_ENDPOINT:5432/verae?sslmode=verify-full&sslrootcert=/etc/ssl/certs/aws-rds-global-bundle.pem
