# Application environment for AWS Lightsail production.
# Copy to server/.env.production on the production instance (chmod 600).
# Generate every secret independently: openssl rand -base64 32
# URL-encode database passwords inside connection URLs.
NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Lightsail managed database (private endpoint, public mode OFF).
# migrate.js creates the roles; provision-logins.js sets these passwords.
DATABASE_URL=postgres://verae_api_login:CHANGE_ME@PRIVATE_DB_ENDPOINT:5432/verae?sslmode=verify-full&sslrootcert=/etc/ssl/certs/aws-rds-global-bundle.pem
AUTH_DATABASE_URL=postgres://verae_auth_login:CHANGE_ME@PRIVATE_DB_ENDPOINT:5432/verae?sslmode=verify-full&sslrootcert=/etc/ssl/certs/aws-rds-global-bundle.pem
WORKER_DATABASE_URL=postgres://verae_worker_login:CHANGE_ME@PRIVATE_DB_ENDPOINT:5432/verae?sslmode=verify-full&sslrootcert=/etc/ssl/certs/aws-rds-global-bundle.pem
JOBS_DATABASE_URL=postgres://verae_jobs_login:CHANGE_ME@PRIVATE_DB_ENDPOINT:5432/verae?sslmode=verify-full&sslrootcert=/etc/ssl/certs/aws-rds-global-bundle.pem

BETTER_AUTH_SECRET=CHANGE_ME_32_CHARS_MIN
BETTER_AUTH_URL=https://api.veraehealth.com
APP_ORIGIN=https://app.veraehealth.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_URL=
EMAIL_FROM=Verae Health <noreply@veraehealth.com>
TURNSTILE_SECRET_KEY=

# Lightsail bucket (S3-compatible), ap-southeast-5 (Malaysia).
S3_ENDPOINT=https://s3.ap-southeast-5.amazonaws.com
S3_REGION=ap-southeast-5
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_DOCUMENTS_BUCKET=CHANGE_ME
S3_BACKUPS_BUCKET=CHANGE_ME
S3_FORCE_PATH_STYLE=false

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
PARTNER_CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME
REQUIRE_STAFF_MFA=true
# Leave EXPOSE_API_DOCS unset in production: /docs and the OpenAPI spec stay
# closed so the full route map is not publicly enumerable.
LOG_LEVEL=info
